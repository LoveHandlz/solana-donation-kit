<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Donate SOL • Support with Phantom</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://unpkg.com/@solana/web3.js@1.95.3/dist/index.iife.min.js"></script>
    <style>
        body { font-family: system_ui, sans-serif; }
        .sol-bg { background: linear-gradient(135deg, #14b8a6, #0f766e); }
    </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen">

    <div class="max-w-2xl mx-auto px-6 py-16">
        <div class="text-center mb-12">
            <div class="text-7xl mb-4">🪙</div>
            <h1 class="text-5xl font-bold tracking-tight">Donate with Solana</h1>
            <p class="text-teal-400 text-xl mt-2">Powered by Phantom Wallet</p>
        </div>

        <!-- Connection Status -->
        <div id="status" class="bg-zinc-900 rounded-3xl p-6 mb-8 text-center min-h-[80px]"></div>

        <!-- Wallet Info -->
        <div id="walletInfo" class="hidden bg-zinc-900 rounded-3xl p-8 mb-10 border border-teal-500">
            <p class="text-sm text-zinc-400 mb-2">Connected Wallet</p>
            <div class="font-mono text-sm bg-zinc-800 p-4 rounded-2xl break-all" id="connectedAddress"></div>
        </div>

        <!-- Donation Section -->
        <div class="bg-zinc-900 rounded-3xl p-10">
            <h2 class="text-3xl font-semibold text-center mb-8">Choose how much to send</h2>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
                <button onclick="quickDonate(0.1)" class="bg-zinc-800 hover:bg-teal-600 py-6 rounded-2xl font-bold text-xl transition-colors">0.1 SOL</button>
                <button onclick="quickDonate(0.5)" class="bg-zinc-800 hover:bg-teal-600 py-6 rounded-2xl font-bold text-xl transition-colors">0.5 SOL</button>
                <button onclick="quickDonate(1)" class="bg-zinc-800 hover:bg-teal-600 py-6 rounded-2xl font-bold text-xl transition-colors">1 SOL</button>
                <button onclick="quickDonate(5)" class="bg-zinc-800 hover:bg-teal-600 py-6 rounded-2xl font-bold text-xl transition-colors">5 SOL</button>
            </div>

            <div class="flex gap-4">
                <input id="customAmount" type="number" step="0.01" min="0.01" placeholder="Custom SOL amount" 
                       class="flex-1 bg-zinc-800 px-6 py-5 rounded-2xl text-xl focus:outline-none focus:ring-2 focus:ring-teal-500">
                <button onclick="sendCustom()" 
                        class="bg-teal-500 hover:bg-teal-600 px-12 py-5 rounded-2xl font-bold text-xl transition-all">
                    Send
                </button>
            </div>

            <p class="text-center text-zinc-500 text-sm mt-10">
                You will be asked to approve the transaction in Phantom.<br>
                All SOL goes directly to the recipient address.
            </p>
        </div>
    </div>

    <script>
        // ================== CHANGE THIS ==================
        const RECIPIENT = "YOUR_REAL_SOLANA_ADDRESS_HERE";   // ←←← Put your Solana address here
        // ================================================

        let provider;
        let publicKey;

        const connection = new solanaWeb3.Connection(
            "https://api.mainnet-beta.solana.com", 
            "confirmed"
        );

        function showStatus(message, isError = false) {
            const el = document.getElementById('status');
            el.innerHTML = `<span class="${isError ? 'text-red-400' : 'text-teal-400'}">${message}</span>`;
        }

        async function connectWallet() {
            try {
                if (!window.solana || !window.solana.isPhantom) {
                    showStatus("❌ Phantom wallet not found. Please install Phantom extension.", true);
                    window.open("https://phantom.app/", "_blank");
                    return;
                }

                provider = window.solana;
                const resp = await provider.connect();
                publicKey = resp.publicKey;

                document.getElementById('walletInfo').classList.remove('hidden');
                document.getElementById('connectedAddress').textContent = publicKey.toString();

                showStatus("✅ Wallet connected successfully!");

            } catch (err) {
                showStatus("❌ Failed to connect. Make sure Phantom is unlocked.", true);
                console.error(err);
            }
        }

        async function sendTransaction(amount) {
            if (!publicKey) {
                showStatus("❌ Please connect your wallet first!", true);
                return;
            }
            if (!RECIPIENT || RECIPIENT.includes("YOUR_REAL")) {
                showStatus("❌ Please replace YOUR_REAL_SOLANA_ADDRESS_HERE with your actual address!", true);
                return;
            }

            try {
                showStatus("Creating transaction...");

                const transaction = new solanaWeb3.Transaction().add(
                    solanaWeb3.SystemProgram.transfer({
                        fromPubkey: publicKey,
                        toPubkey: new solanaWeb3.PublicKey(RECIPIENT),
                        lamports: amount * solanaWeb3.LAMPORTS_PER_SOL
                    })
                );

                showStatus("Please approve in Phantom...");

                const signed = await provider.signAndSendTransaction(transaction);
                
                showStatus(`✅ Transaction sent!<br>Signature: ${signed.signature.substring(0, 20)}...`);

            } catch (err) {
                console.error(err);
                showStatus("❌ Transaction cancelled or failed.", true);
            }
        }

        function quickDonate(amount) {
            sendTransaction(amount);
        }

        function sendCustom() {
            const amount = parseFloat(document.getElementById('customAmount').value);
            if (!amount || amount <= 0) {
                showStatus("Please enter a valid amount", true);
                return;
            }
            sendTransaction(amount);
        }

        // Auto-check if Phantom is available
        window.onload = () => {
            if (!window.solana || !window.solana.isPhantom) {
                showStatus("Phantom wallet not detected yet.<br>Click the Connect button below after installing it.");
            } else {
                showStatus('Phantom detected! Click "Connect Wallet" to begin.');
            }
        };
    </script>

    <!-- Connect Button (placed at bottom for easy access) -->
    <div class="fixed bottom-8 left-1/2 -translate-x-1/2">
        <button onclick="connectWallet()" 
                class="bg-white text-black font-bold text-2xl px-10 py-5 rounded-3xl shadow-2xl hover:scale-105 transition-all flex items-center gap-3">
            <i class="fas fa-wallet"></i> Connect Phantom Wallet
        </button>
    </div>

</body>
</html>
